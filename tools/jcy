#!/bin/bash
# jcy - SSH + tmux 智能连接脚本
# 用法: jcy [选项]
#   jcy          交互式选择
#   jcy -n       直接创建新会话
#   jcy -l       仅列出会话

set -e

# ========== 配置区 ==========
REMOTE_HOST="jack@192.168.10.200"
SESSION_PREFIX="work"  # 会话前缀

# ========== 颜色定义 ==========
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# ========== 函数定义 ==========

print_header() {
    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════════╗"
    echo "║     🚀 jcy - SSH + tmux 智能连接         ║"
    echo "╚══════════════════════════════════════════╝"
    echo -e "${NC}"
}

get_sessions() {
    # 获取远程 tmux 会话列表，格式：会话名|窗口数|是否附加|创建时间
    ssh "$REMOTE_HOST" "tmux list-sessions -F '#{session_name}|#{session_windows}|#{?session_attached,yes,no}|#{session_created}' 2>/dev/null" || echo ""
}

format_session_time() {
    local timestamp=$1
    # 将时间戳转换为可读格式（远程执行 date）
    ssh "$REMOTE_HOST" "date -d @$timestamp '+%m-%d %H:%M'" 2>/dev/null || echo "未知"
}

display_sessions() {
    local sessions=$1
    local index=1

    echo -e "${YELLOW}📋 现有 tmux 会话：${NC}"
    echo ""
    echo -e "  ${BLUE}序号  会话名称                窗口  状态      创建时间${NC}"
    echo "  ─────────────────────────────────────────────────────"

    while IFS='|' read -r name windows attached created; do
        local status_icon="💤"
        local status_text="空闲"
        if [ "$attached" = "yes" ]; then
            status_icon="🔗"
            status_text="使用中"
        fi

        local time_str=$(format_session_time "$created")
        printf "  ${GREEN}%2d${NC})  %-20s   %2s    %s %-6s  %s\n" \
            "$index" "$name" "$windows" "$status_icon" "$status_text" "$time_str"
        ((index++))
    done <<< "$sessions"

    echo ""
}

show_menu() {
    local has_sessions=$1

    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  ${GREEN}0${NC}) 🆕  创建新会话"
    if [ "$has_sessions" = "true" ]; then
        echo "  ${GREEN}1-9${NC}) 🔌 连接对应会话"
    fi
    echo "  ${GREEN}q${NC}) 🚪  直接登录（不用 tmux）"
    echo "  ${GREEN}x${NC}) ❌  退出"
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

create_new_session() {
    local session_name="${SESSION_PREFIX}_$(date +%Y%m%d_%H%M%S)"
    echo -e "${GREEN}✨ 创建新会话: $session_name${NC}"
    ssh -t "$REMOTE_HOST" "tmux new-session -s '$session_name'"
}

attach_session() {
    local sessions=$1
    local choice=$2

    # 获取选中的会话名
    local session_name=$(echo "$sessions" | sed -n "${choice}p" | cut -d'|' -f1)

    if [ -z "$session_name" ]; then
        echo -e "${RED}❌ 无效的选择${NC}"
        exit 1
    fi

    echo -e "${GREEN}🔌 连接会话: $session_name${NC}"
    ssh -t "$REMOTE_HOST" "tmux attach -t '$session_name'"
}

direct_login() {
    echo -e "${GREEN}🚪 直接 SSH 登录（无 tmux）${NC}"
    ssh "$REMOTE_HOST"
}

list_only() {
    local sessions=$(get_sessions)
    if [ -z "$sessions" ]; then
        echo -e "${YELLOW}📭 当前没有 tmux 会话${NC}"
    else
        display_sessions "$sessions"
    fi
}

# ========== 主逻辑 ==========

# 解析参数
case "${1:-}" in
    -n|--new)
        create_new_session
        exit 0
        ;;
    -l|--list)
        list_only
        exit 0
        ;;
    -h|--help)
        echo "用法: jcy [选项]"
        echo "  jcy          交互式选择"
        echo "  jcy -n       直接创建新会话"
        echo "  jcy -l       仅列出会话"
        echo "  jcy -h       显示帮助"
        exit 0
        ;;
esac

# 交互式主流程
print_header

# 获取会话列表
sessions=$(get_sessions)
has_sessions="false"
session_count=0

if [ -n "$sessions" ]; then
    has_sessions="true"
    session_count=$(echo "$sessions" | wc -l)
    display_sessions "$sessions"
else
    echo -e "${YELLOW}📭 当前没有 tmux 会话${NC}"
    echo ""
fi

show_menu "$has_sessions"

# 读取用户选择
read -p "请选择 [0-9/q/x]: " choice

case "$choice" in
    0)
        create_new_session
        ;;
    q|Q)
        direct_login
        ;;
    x|X)
        echo -e "${GREEN}👋 再见！${NC}"
        exit 0
        ;;
    [1-9])
        if [ "$has_sessions" = "true" ] && [ "$choice" -le "$session_count" ]; then
            attach_session "$sessions" "$choice"
        else
            echo -e "${RED}❌ 无效的选择，没有第 $choice 个会话${NC}"
            exit 1
        fi
        ;;
    *)
        echo -e "${RED}❌ 无效的输入: $choice${NC}"
        exit 1
        ;;
esac
